#!/bin/bash

set -euo pipefail

third_monitor="DP-6"

status=$(kscreen-doctor -o 2>/dev/null \
    | grep -A2 "Output.*${third_monitor}" \
    | grep -oE "enabled|disabled")

if [[ "$status" == "enabled" ]]; then
    kscreen-doctor "output.${third_monitor}.disable"
    echo "🖥️ ❌ ${third_monitor} disabled"
elif [[ "$status" == "disabled" ]]; then
    kscreen-doctor \
        "output.${third_monitor}.enable" \
        "output.${third_monitor}.position.1600,-1200"
    echo "🖥️ ✅ ${third_monitor} enabled"
else
    echo "❌ Display ${third_monitor} not detected" >&2
    exit 1
fi